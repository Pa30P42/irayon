# =============================================================================
# DATABASE — leave empty in dev to keep the API on mock data.
# =============================================================================
#
# Local Postgres:
#   DATABASE_URL="postgresql://user:password@localhost:5432/irayon?schema=public"
#
# Supabase (recommended for production):
#   1. Create a project at https://supabase.com/dashboard
#   2. Project Settings → Database → Connection String
#   3. Pick "Transaction" pooler URL (port 6543) for runtime queries:
#      DATABASE_URL="postgres://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   4. Pick "Session" / direct URL (port 5432) for migrations & seeding:
#      DIRECT_URL="postgres://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
#
# When DATABASE_URL is empty, the API falls back to in-memory mock data so the
# app keeps working in dev without any DB. Phase B: drop in the URLs and run
#   pnpm prisma:migrate
#   pnpm prisma:seed
DATABASE_URL=""
DIRECT_URL=""

# =============================================================================
# SITE URL — the public origin where the app is served. Drives canonical URLs,
# hreflang alternates, sitemap, robots.txt, and the production-domain SEO gate.
#
# Vercel envs:
#   Production : https://irayon.az
#   Preview    : https://irayon.vercel.app  (or the per-PR preview URL)
#   Development: http://localhost:3000      (or leave unset; localhost is the default)
#
# Anything other than `irayon.az` flips the SEO gate to "noindex everywhere"
# (robots.txt becomes Disallow: /, sitemap returns empty, page-level meta is
# noindex,nofollow). All SEO code stays in place — it just hibernates until
# the real domain is connected.
# =============================================================================
NEXT_PUBLIC_SITE_URL="https://irayon.az"

# Legacy alias — `NEXT_PUBLIC_SITE_URL` overrides this if both are set.
# Safe to remove once your local `.env` only uses NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# ADMIN PANEL — credentials for the /admin/login form + signing key for the
# session cookie. ADMIN_SESSION_SECRET must be at least 32 characters; pick a
# random one (e.g. `openssl rand -base64 48`) and keep it out of git.
# =============================================================================
ADMIN_LOGIN=""
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""

# =============================================================================
# SEARCH-ENGINE VERIFICATION — paste the token strings (NOT the full meta tag)
# from each console. Set in Vercel production only; previews/dev can stay empty.
#   Google Search Console : https://search.google.com/search-console
#     Property → Settings → Ownership verification → HTML tag → copy the
#     `content="…"` value into GOOGLE_SITE_VERIFICATION.
#   Yandex Webmaster      : https://webmaster.yandex.com
#     Add site → Meta tag → copy the `content="…"` value into
#     YANDEX_VERIFICATION.
# When empty the verification meta tag is omitted (no broken markup).
# =============================================================================
GOOGLE_SITE_VERIFICATION=""
YANDEX_VERIFICATION=""
